# ── App ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=true
LOG_LEVEL=INFO

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama          # ollama | mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=qdrant     # qdrant | in_memory
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=industrial_docs

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=sentence_transformers   # sentence_transformers | mock
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG_LLM=false              # Set true to log the full LLM prompt to console
